{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"src/**/*.{css,scss,vue}\" --allow-empty-input",
    "lint:style:fix": "stylelint \"src/**/*.{css,scss,vue}\" --allow-empty-input --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,scss}\"",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "check": "pnpm run type-check && pnpm run lint && pnpm run lint:style && pnpm run format:check",
    "prepare": "node scripts/prepare-hooks.mjs"
  },
  "dependencies": {
    "@unocss/reset": "^66.7.5",
    "alova": "^3.5.2",
    "pinia": "^4.0.2",
    "unplugin-auto-import": "^21.0.0",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/css": "^1.4.0",
    "@eslint/json": "^2.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.1",
    "naive-ui": "^2.44.1",
    "npm-run-all2": "^9.0.2",
    "postcss-html": "^1.8.1",
    "prettier": "3.9.5",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.65.0",
    "unplugin-vue-components": "^32.1.0",
    "vfonts": "^0.0.3",
    "vite": "^8.1.5",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
