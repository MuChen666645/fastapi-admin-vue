APP_ENV=staging
APP_ENV_FILE=.env.staging
DEBUG=false

MYSQL_HOST=staging-mysql
MYSQL_POST=3306
MYSQL_USERNAME=staging_app
MYSQL_PASSWORD=REPLACE_WITH_STAGING_MYSQL_PASSWORD
MYSQL_DATABASES=fastapi_admin
TIMEZONE=Asia/Shanghai

REDIS_HOST=staging-redis
REDIS_USERNAME=default
REDIS_PASSWORD=REPLACE_WITH_STAGING_REDIS_PASSWORD
REDIS_POST=6379
REDIS_DB=0

SECRET_KEY=REPLACE_WITH_A_RANDOM_STAGING_SECRET_AT_LEAST_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=3600
ADMIN_ROLE_CODE=admin

ACCESS_KEY_ID=REPLACE_WITH_STAGING_OSS_ACCESS_KEY_ID
ACCESSKEY_SECRET=REPLACE_WITH_STAGING_OSS_ACCESS_KEY_SECRET

HOSTS=["admin-staging.example.com"]
TRUSTED_PROXIES=[]
ORIGINS=["https://admin-staging.example.com"]
MEDOTHS=["GET","POST","PUT","DELETE","OPTIONS"]
HEADERS=["Authorization","Content-Type","X-Requested-With"]
CREDENTIALS=true
